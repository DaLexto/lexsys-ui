{
  "name": "lexsys",
  "private": true,
  "version": "0.0.0",
  "description": "A registry-first React UI framework that generates copyable components directly into your project, powered by Base UI, Tailwind CSS, and a full design token system.",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm format:check && pnpm lint:root && turbo run check",
    "dev": "turbo run dev",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "pnpm lint:root && turbo run lint",
    "lint:fix": "pnpm lint:root:fix && turbo run lint:fix",
    "lint:root": "eslint *.config.mjs --max-warnings=0",
    "lint:root:fix": "eslint *.config.mjs --fix",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "sync:all": "pnpm registry:sync && pnpm tokens:generate:styles",
    "sync:styles": "pnpm tokens:generate:styles",
    "sync:templates": "pnpm registry:sync",
    "tokens:build": "pnpm --filter @lexsys/tokens build",
    "tokens:check": "pnpm --filter @lexsys/tokens check",
    "tokens:generate:styles": "pnpm --filter @lexsys/tokens generate:styles",
    "tokens:governance:report": "pnpm --filter @lexsys/tokens governance:report",
    "tokens:imports:clean": "pnpm --filter @lexsys/tokens imports:clean",
    "tokens:lint:fix": "pnpm --filter @lexsys/tokens lint:fix",
    "tokens:typecheck": "pnpm --filter @lexsys/tokens typecheck",
    "ui:build": "pnpm --filter @lexsys/ui build",
    "ui:check": "pnpm --filter @lexsys/ui check",
    "ui:audit": "pnpm --filter @lexsys/ui run audit",
    "ui:lint:fix": "pnpm --filter @lexsys/ui lint:fix",
    "ui:typecheck": "pnpm --filter @lexsys/ui typecheck",
    "registry:build": "pnpm --filter @lexsys/registry build",
    "registry:check": "pnpm --filter @lexsys/registry check",
    "registry:lint:fix": "pnpm --filter @lexsys/registry lint:fix",
    "registry:styles:sync": "pnpm --filter @lexsys/registry styles:sync",
    "registry:sync": "pnpm --filter @lexsys/registry templates:sync",
    "registry:typecheck": "pnpm --filter @lexsys/registry typecheck",
    "cli:build": "pnpm --filter ./packages/cli build",
    "cli:check": "pnpm turbo run check --filter=./packages/cli",
    "cli:lint:fix": "pnpm --filter ./packages/cli lint:fix",
    "cli:typecheck": "pnpm --filter ./packages/cli typecheck",
    "playground:build": "pnpm tokens:build && pnpm ui:build && pnpm --filter @lexsys/playground build",
    "playground:check": "pnpm --filter @lexsys/playground check",
    "playground:dev": "pnpm --filter @lexsys/playground dev",
    "playground:lint": "pnpm --filter @lexsys/playground lint",
    "playground:lint:fix": "pnpm --filter @lexsys/playground lint:fix",
    "playground:typecheck": "pnpm tokens:build && pnpm ui:build && pnpm --filter @lexsys/playground typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/prompts": "^2.4.9",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "turbo": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "typescript",
    "tailwindcss"
  ],
  "author": "DaLexto",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "prompts": "^2.4.2"
  }
}
