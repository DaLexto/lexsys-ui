{
  "name": "neurex",
  "private": true,
  "version": "0.0.0",
  "description": "A registry-first React UI framework that generates copyable components directly into your project, powered by Base UI, Tailwind CSS, and a full design token system.",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "pnpm lint:root && turbo run lint",
    "lint:fix": "pnpm lint:root:fix && turbo run lint:fix",
    "lint:root": "eslint *.config.mjs --max-warnings=0",
    "lint:root:fix": "eslint *.config.mjs --fix",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "cli:build": "pnpm --filter ./packages/cli build",
    "cli:typecheck": "pnpm --filter ./packages/cli typecheck",
    "cli:check": "pnpm --filter ./packages/cli check",
    "registry:build": "pnpm --filter ./packages/registry build",
    "registry:typecheck": "pnpm --filter ./packages/registry typecheck",
    "registry:check": "pnpm --filter ./packages/registry check",
    "playground:dev": "pnpm --filter @neurex/playground dev",
    "playground:build": "pnpm --filter @neurex/tokens build && pnpm --filter @neurex/ui build && pnpm --filter @neurex/playground build",
    "playground:typecheck": "pnpm --filter @neurex/tokens build && pnpm --filter @neurex/ui build && pnpm --filter @neurex/playground typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.5.1",
    "turbo": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "typescript",
    "tailwindcss"
  ],
  "author": "DaLexto",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "prompts": "^2.4.2"
  }
}
