{
  "$schema": "./rebrand-map.schema.json",
  "brand": {
    "product": { "from": "neurex", "to": "lexsys" },
    "productTitle": { "from": "Neurex", "to": "Lexsys" },
    "cssVarPrefix": { "from": "nx", "to": "lsys" },
    "tailwindPrefix": { "from": "nx", "to": "twix" },
    "semanticClassPrefix": { "from": "nx-", "to": "lsys-" }
  },
  "skipSubstrings": [
    "npm.im/neurex",
    "github.com/KarkAngelo114/Neurex",
    "karkangelo",
    "neurex-runtime",
    "scripts/rebrand/",
    "docs/REBRAND.md"
  ],
  "ignoreDirs": [
    "node_modules",
    "dist",
    ".git",
    ".turbo",
    ".pnpm-store",
    ".tmp",
    "agent-transcripts"
  ],
  "fileRenames": [
    {
      "from": "packages/tokens/src/brand/neurex.brand.ts",
      "to": "packages/tokens/src/brand/lexsys.brand.ts"
    },
    {
      "from": "packages/tokens/src/presets/neurex.preset.ts",
      "to": "packages/tokens/src/presets/lexsys.preset.ts"
    },
    {
      "from": "packages/tokens/src/themes/neurex/light.ts",
      "to": "packages/tokens/src/themes/lexsys/light.ts"
    },
    {
      "from": "packages/tokens/src/themes/neurex/dark.ts",
      "to": "packages/tokens/src/themes/lexsys/dark.ts"
    },
    {
      "from": ".cursor/rules/neurex-testing.mdc",
      "to": ".cursor/rules/lexsys-testing.mdc"
    }
  ],
  "phases": {
    "workspace": {
      "globs": [
        "package.json",
        "pnpm-workspace.yaml",
        "tsconfig.base.json",
        "packages/*/package.json",
        "apps/*/package.json",
        "turbo.json"
      ]
    },
    "cli": {
      "globs": [
        "packages/cli/**/*.ts",
        "packages/cli/**/*.json",
        "packages/cli/README.md"
      ]
    },
    "tokens": {
      "globs": [
        "packages/tokens/**/*.ts",
        "packages/tokens/**/*.json",
        "packages/tokens/README.md",
        "packages/registry/scripts/**/*.mjs"
      ]
    },
    "variants": {
      "globs": [
        "packages/ui/**/*.ts",
        "packages/ui/**/*.tsx",
        "packages/registry/templates/**/*.ts",
        "packages/registry/templates/**/*.tsx",
        "packages/registry/templates/**/*.css"
      ]
    },
    "docs": {
      "globs": [
        "docs/**/*.md",
        "README.md",
        "CONTRIBUTING.md",
        "AGENTS.md",
        ".cursor/rules/**/*.mdc",
        ".agents/**/*.md",
        ".github/**/*.md",
        ".github/**/*.yml",
        "apps/playground/**/*.md",
        "apps/playground/**/*.tsx",
        "apps/playground/**/*.css",
        "packages/**/README.md",
        ".vscode/**/*.json"
      ]
    }
  }
}
