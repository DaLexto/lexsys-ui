{
  "name": "@neurex/registry",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "templates"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./templates/*": "./templates/*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run templates:typecheck && pnpm run test",
    "lint": "eslint src templates --max-warnings=0",
    "lint:fix": "eslint src templates --fix",
    "templates:typecheck": "tsc -p templates/tsconfig.json",
    "test": "vitest run --passWithNoTests --pool threads --exclude \"dist/**\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
