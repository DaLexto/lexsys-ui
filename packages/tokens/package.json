{
  "name": "@neurex/tokens",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": [
    "./dist/tokens.css",
    "./dist/theme.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./dist/theme.css",
    "./tokens.css": "./dist/tokens.css"
  },
  "scripts": {
    "build": "tsup && node dist/generators/write-style-outputs.js --package",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "generate:styles": "tsup && node dist/generators/write-style-outputs.js --package --registry",
    "lint": "eslint src test --max-warnings=0",
    "lint:fix": "eslint src test --fix",
    "test": "vitest run test --passWithNoTests --pool threads --exclude \"dist/**\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
