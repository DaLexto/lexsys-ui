{
  "name": "@dalexto/lexsys-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.json --emitDeclarationOnly --outDir dist",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run audit",
    "lint": "eslint src test --max-warnings=0",
    "lint:fix": "eslint src test --fix",
    "test": "vitest run test --passWithNoTests --pool threads --exclude \"dist/**\"",
    "audit": "node scripts/audit-variants.mjs && node scripts/audit-compound-exports.mjs check",
    "audit:catalog:check": "node scripts/audit-compound-exports.mjs check",
    "audit:catalog:write": "node scripts/audit-compound-exports.mjs write",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dalexto/lexsys-tokens": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
