{
  "name": "neurex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "neurex": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.json --emitDeclarationOnly --outDir dist",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "lint": "eslint src test --max-warnings=0",
    "lint:fix": "eslint src test --fix",
    "test": "vitest run test --passWithNoTests --pool threads --exclude \"dist/**\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@neurex/registry": "workspace:*",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/prompts": "^2.4.9"
  }
}
