{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@dalexto/lexsys-registry": ["./packages/registry/dist/index.d.ts"],
      "@dalexto/lexsys-registry/templates/*": [
        "./packages/registry/templates/*"
      ],
      "@dalexto/lexsys-tokens": ["./packages/tokens/dist/index.d.ts"],
      "@dalexto/lexsys-ui": ["./packages/ui/dist/index.d.ts"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  }
}
