{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@lexsys/registry": ["./packages/registry/dist/index.d.ts"],
      "@lexsys/registry/templates/*": ["./packages/registry/templates/*"],
      "@lexsys/tokens": ["./packages/tokens/dist/index.d.ts"],
      "@lexsys/ui": ["./packages/ui/dist/index.d.ts"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  }
}
